generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       Int    @id @default(autoincrement())
  nome     String
  email    String @unique
  whatsapp String
  tags     Tag[]
}

model Tag {
  id     Int    @id @default(autoincrement())
  codigo String @unique
  status String
  userId Int?
  user   User?  @relation(fields: [userId], references: [id])
}

model Order {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String
  telefone  String
  cpf       String
  produto   String
  cep       String
  rua       String
  numero    String
  cidade    String
  estado    String
  status    String
  rastreio  String?
  createdAt DateTime @default(now())
}
