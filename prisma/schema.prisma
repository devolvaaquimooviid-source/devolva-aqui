generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ==========================
// USER
// ==========================
model User {
  id        Int     @id @default(autoincrement())
  nome      String
  email     String  @unique
  whatsapp  String

  tags      Tag[]
}

// ==========================
// TAG
// ==========================
model Tag {
  id      Int    @id @default(autoincrement())
  codigo  String @unique
  status  String

  userId  Int?
  user    User?  @relation(fields: [userId], references: [id])
}

// ==========================
// ORDER (PEDIDOS)
// ==========================
model Order {
  id        Int     @id @default(autoincrement())
  nome      String
  email     String
  telefone  String
  cpf       String          // 👈 CAMPO NOVO
  produto   String
  cep       String
  rua       String
  numero    String
  cidade    String
  estado    String
  status    String
  rastreio  String?
}
