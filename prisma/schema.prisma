generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Order {
  id        String @id @default(cuid())

  nome      String
  cpf       String @unique
  endereco  String
  cidade    String
  estado    String
  cep       String

  createdAt DateTime @default(now())
}